{% extends 'base.html.twig' %}

{% block title %}Dasboard{% endblock %}

{% block body %}
    <section class="flex flex-row h-screen w-full">
        <section class="bg-[#F9FAFB] w-1/4 flex flex-col gap-2 p-4 border-r border-gray-300">
            <div>
                <button class="bg-black text-white font-bold py-2 px-4 rounded-md w-full">
                     Toutes les Tâches
                </button>
            </div>
                <h1 class="text-gray-500 font-bold mb-4" >DOSSIERS</h1>
            <div class="flex flex-col gap-2">
             {%if folders%}
             {% for folder in folders %}
                <div class="flex items-center gap-2">
                    
                    <span style="display: inline-block; width: 1rem; height: 1rem; 
                    background-color: {{ folder.color ?? '#CCCCCC' }}; border-radius: 0;"></span>
                    
                    <a href="{{ path('app_folder_show', {'id': folder.id}) }}"class="flex gap-4 items-center w-full rounded-md hover:bg-gray-200">  
                    
                        <span>{{ ux_icon('tabler:folder', { class: 'w-4 h-4' }) }}</span>
                        <p>{{ folder.name }}</p>
                    </a>
                        <span class="text-gray-700 text-sm text-right">{{ folder.tasks|length }}</span>
                    
                </div>
                {%endfor%}
                {%else%}
                <p class="text-gray-500">Aucun dossier cree</p>
                {%endif%}
            </div>

        </section>
        <section class="bg-white w-full flex flex-col " >
            <div class="flex flex-row justify-between items-center w-full px-6 py-4">
                <div>
                    <h1 class="mb-4">Gestion de Tâches</h1>
                    <p class="text-gray-400">Organisez votre journée efficacement</p>
                </div>
                <div class="flex flex-row gap-2 justify-end-safe p-2 ">
                    <button>
                     Gérer les Priorités
                    </button>
                    <button class="border border-gray-300 p-1 rounded-lg"><a href="{{ path('app_folder_new') }}">+
                     Nouveau Dossier
                     </button>
                    <button class="bg-black text-white p-1 font-bold rounded-lg">
                     <a href="{{ path('app_task_new') }}">+ Nouvelle Tâche</a>
                    </button>
                    <button class="border border-gray-300 p-1 rounded-lg">
                     Deconnexion
                    </button>
                </div>

            </div>
            <div class="bg-[#F9FAFB] border-y border-gray-300 px-6 py-4">
                <div class="flex ">
                    <p>filtres: </p>
                    <p>status tous</p>
                    <p>priorite tous</p>

                </div>
            </div>
            <div>
                <p class="text-gray-500 text-center mt-4">Aucune tâche trouvée. Créez votre première tâche pour commencer à organiser votre journée !</p>
                
            </div>
        </section>

    </section>
{% endblock %}
