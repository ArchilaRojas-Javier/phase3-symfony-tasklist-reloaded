{% extends 'base.html.twig' %}

{% block title %}Log in!
{% endblock %}

{% block body %}

	<section class="flex justify-center h-screen items-center bg-[#E0E7FF]">
		<div class="bg-white rounded-2xl border-[#0000001A] border p-6">
			<div>
				<h1 class=" text-gray-800 mb-4">Gestion de Tâches</h1>
            </div>
			<p class="text-gray-600">Organisez votre journée efficacement</p>
			<div class="flex justify-around bg-gray-300 rounded-xl">
				<button class="btn  bg-white text-black rounded-xl m-1 w-full ">Connexion</button>
				<button class="btn w-full">Inscription</button>
			</div>
			<div>
				<form method="post" class="flex flex-col gap-4 ">
					{% if error %}
						<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
					{% endif %}

					{% if app.user %}
						<div class="mb-3">
							You are logged in as
							{{ app.user.userIdentifier }},
							<a href="{{ logout_path() }}">Logout</a>
						</div>
					{% endif %}

					
					<label for="username">Email</label>
					<input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control bg-[#F3F4F6] rounded-md" autocomplete="email" required autofocus placeholder="votre@email.com">
					<label for="password">Mot de passe</label>
					<input type="password" name="_password" id="password" class="form-control  bg-[#F3F4F6] rounded-md" autocomplete="current-password" required placeholder="********">
					<input
					type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

					{#
					            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
					            See https://symfony.com/doc/current/security/remember_me.html
					
					            <div class="checkbox mb-3">
					                <input type="checkbox" name="_remember_me" id="_remember_me">
					                <label for="_remember_me">Remember me</label>
					            </div>
					        #}

					<button class="btn btn-lg btn-primary  bg-black text-white w-full rounded-sm" type="submit">
						Se connecter
					</button>
				</form>


			</div>


		</div>
	</section>

{% endblock %}
