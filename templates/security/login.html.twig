{% extends 'base.html.twig' %}

{% block title %}Log in!
{% endblock %}

{% block body %}

	<section class="bg-[#E0E7FF] h-screen flex items-center justify-center">
		<div class="bg-white flex flex-col p-6 gap-4 rounded-xl shadow-md w-full max-w-md">
			<div>
				<h1>Gestion de Tâches</h1>
			</div>
			<p class="text-gray-600">Organisez votre journée efficacement.</p>
			<div class="flex justify-around gap-2 bg-gray-300 h-9 rounded-md">
				<button class="btn m-1 w-full bg-white rounded-xl">
					<a href="{{ path('app_login') }}">Connexion</a>
				</button>
				<button class="btn m-1  w-full rounded-md">
						<a href="{{ path('app_register') }}">Inscription</a>
				</button>
			</div>
			<div >
				<form method="post"class="flex flex-col">
					{% if error %}
						<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
					{% endif %}

					{# {% if app.user %}
											<div class="mb-3">
												You are logged in as
												{{ app.user.userIdentifier }},
												<a href="{{ logout_path() }}">Logout</a>
											</div>
										{% endif %} #}


					<label for="username">Email</label>
					<input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control w-full h-9 text-gray-600 bg-[#F3F3F5] mb-4 rounded-md" autocomplete="email" required autofocus placeholder="votre@email.com">
					<label for="password">Mot de passe</label>
					<input type="password" name="_password" id="password" class="form-control w-full h-9 text-gray-600 bg-[#F3F3F5] mb-4 rounded-md" autocomplete="current-password" required placeholder="*******">
					<input
					type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

					{#
															            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
															            See https://symfony.com/doc/current/security/remember_me.html
															
															            <div class="checkbox mb-3">
															                <input type="checkbox" name="_remember_me" id="_remember_me">
															                <label for="_remember_me">Remember me</label>
															            </div>
															        #}

					<button class="btn btn-lg btn-primary  h-10 bg-black text-white w-full rounded-sm" type="submit">
						Se connecter
					</button>
				</form>
			</div>
		</div>
	</section>


{% endblock %}
